# Gemini API (required unless BOOKLY_AGENT_MOCK_LLM=true)
GEMINI_API_KEY=

# Model and timeouts
BOOKLY_AGENT_MODEL=gemini-2.5-flash
BOOKLY_AGENT_TIMEOUT_SECONDS=15

# Use deterministic mock LLM for offline dev/CI
BOOKLY_AGENT_MOCK_LLM=false

# Path to mock order data (optional; defaults to package data)
BOOKLY_AGENT_DATA_PATH=
